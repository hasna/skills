{
  "name": "@hasnaxyz/skill-tmux-session",
  "version": "0.1.0",
  "description": "Instruction-set skill for creating grouped tmux sessions with repo-aware naming",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "skill-tmux-session": "src/index.ts"
  },
  "files": [
    "src",
    "SKILL.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "tmux",
    "sessions",
    "workspace",
    "automation",
    "skill"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
