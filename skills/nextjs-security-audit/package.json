{
  "name": "nextjs-security-audit",
  "version": "0.1.0",
  "description": "Security review for Next. Windows / PowerShell / cmd",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "nextjs-security-audit": "src/index.ts"
  },
  "files": [
    "src",
