{
  "name": "@hasnaxyz/skill-read-csv",
  "version": "0.1.0",
  "description": "Parse CSV files into structured JSON with delimiter and encoding detection",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "skill-read-csv": "src/index.ts"
  },
  "files": [
    "src",
    "SKILL.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "csv",
    "parser",
    "data",
    "cli",
    "skill"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
