{
  "name": "@hasnaxyz/skill-read-image",
  "version": "0.1.0",
  "description": "Analyze local or remote images with Claude vision",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "skill-read-image": "src/index.ts"
  },
  "files": [
    "src",
    "SKILL.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "image",
    "vision",
    "ocr",
    "claude",
    "skill"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
