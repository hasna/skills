{
  "name": "@hasnaxyz/skill-read-excel",
  "version": "0.1.0",
  "description": "Parse XLS and XLSX workbooks into structured JSON",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "skill-read-excel": "src/index.ts"
  },
  "files": [
    "src",
    "SKILL.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "excel",
    "xlsx",
    "xls",
    "spreadsheet",
    "skill"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
