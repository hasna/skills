{
  "name": "domainsearch",
  "version": "0.1.2",
  "type": "module",
  "description": "CLI tool and HTTP API for domain search and availability checking via GoDaddy API",
  "private": true,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "restricted"
  },
  "bin": {
    "domainsearch": "src/index.ts"
  },
  "files": [
    "bin",
    "src",
    "tsconfig.json"
  ],
  "homepage": "https://github.com/hasnaxyz/domainsearch#readme",
  "bugs": {
    "url": "https://github.com/hasnaxyz/domainsearch/issues"
  },
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "cli": "bun run bin/cli.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
